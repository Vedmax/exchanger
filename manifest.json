{
    "manifest_version": 3,
    "name": "Currency Converter Quick Parse",
    "version": "0.1.0",
    "description": "Parses amounts and currencies from selected text and offers conversion.",
    "permissions": ["storage"],
    "action": {
        "default_popup": "src/popup.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["src/content.js"],
            "css": ["src/styles.css"]
        }
    ],
    "background": {
        "service_worker": "src/background.js"
    }
}
